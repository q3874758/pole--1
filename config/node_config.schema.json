{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pole.chain/config/node_config.schema.json",
  "title": "PoLE NodeConfig",
  "description": "Strong-validation schema for the runtime configuration consumed by pole-node and pole-client.",
  "type": "object",
  "required": [
    "chain_id",
    "node_id_hex",
    "reward_address_hex",
    "capabilities",
    "collect",
    "runtime",
    "storage"
  ],
  "additionalProperties": false,
  "properties": {
    "chain_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "pattern": "^[a-zA-Z0-9_-]+$",
      "description": "Bech32 / human-readable chain identifier."
    },
    "node_id_hex": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{64}$",
      "description": "32-byte node identity encoded as 64 hex characters."
    },
    "reward_address_hex": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{40}$",
      "description": "20-byte reward address encoded as 40 hex characters."
    },
    "capabilities": {
      "type": "object",
      "additionalProperties": false,
      "required": ["collect", "store", "verify", "propose", "archive"],
      "properties": {
        "collect": { "type": "boolean" },
        "store": { "type": "boolean" },
        "verify": { "type": "boolean" },
        "propose": { "type": "boolean" },
        "archive": { "type": "boolean" }
      }
    },
    "collect": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "default_epoch_id", "default_slot_id"],
      "properties": {
        "enabled": { "type": "boolean" },
        "default_epoch_id": { "type": "integer", "minimum": 0 },
        "default_slot_id": { "type": "integer", "minimum": 0 }
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "data_dir",
        "poll_interval_secs",
        "slots_per_epoch",
        "target_app_ids"
      ],
      "properties": {
        "data_dir": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4096
        },
        "poll_interval_secs": {
          "type": "integer",
          "minimum": 1,
          "maximum": 86400
        },
        "slots_per_epoch": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1000000
        },
        "challenge_window_blocks": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1000000
        },
        "low_impact_mode": { "type": "boolean" },
        "os_background_priority": { "type": "boolean" },
        "game_active_poll_interval_secs": {
          "type": "integer",
          "minimum": 1,
          "maximum": 3600
        },
        "game_process_names": {
          "type": "array",
          "items": { "type": "string", "minLength": 1, "maxLength": 256 }
        },
        "target_app_ids": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "integer",
            "minimum": 0,
            "maximum": 4294967295
          }
        },
        "p2p_simulation": { "$ref": "#/$defs/p2p_simulation" },
        "p2p_socket": { "$ref": "#/$defs/p2p_socket" },
        "p2p_libp2p": { "$ref": "#/$defs/p2p_libp2p" },
        "activity_sources": {
          "type": "array",
          "items": { "$ref": "#/$defs/activity_source" }
        }
      }
    },
    "storage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["quota_gb", "retention_epochs"],
      "properties": {
        "quota_gb": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1048576
        },
        "retention_epochs": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1000000
        }
      }
    },
    "reward": { "$ref": "#/$defs/reward" }
  },
  "$defs": {
    "p2p_simulation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "batch_listener_count": { "type": "integer", "minimum": 0, "maximum": 1024 },
        "receipt_listener_count": { "type": "integer", "minimum": 0, "maximum": 1024 },
        "dual_listener_count": { "type": "integer", "minimum": 0, "maximum": 1024 }
      }
    },
    "p2p_socket": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "bind_addr": { "type": "string", "minLength": 1, "maxLength": 256 },
        "peers": {
          "type": "array",
          "items": { "$ref": "#/$defs/p2p_socket_peer" }
        }
      }
    },
    "p2p_socket_peer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["peer_id_hex", "addr"],
      "properties": {
        "peer_id_hex": {
          "type": "string",
          "pattern": "^[0-9a-fA-F]{64}$"
        },
        "addr": { "type": "string", "minLength": 1, "maxLength": 256 },
        "topics": {
          "type": "array",
          "items": { "type": "string", "minLength": 1, "maxLength": 64 }
        }
      }
    },
    "p2p_libp2p": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "listen_addrs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1, "maxLength": 256 }
        },
        "bootstrap_peers": {
          "type": "array",
          "items": { "$ref": "#/$defs/p2p_libp2p_bootstrap_peer" }
        },
        "discovery": { "$ref": "#/$defs/p2p_libp2p_discovery" }
      }
    },
    "p2p_libp2p_bootstrap_peer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["peer_id", "addr"],
      "properties": {
        "peer_id": { "type": "string", "minLength": 1, "maxLength": 256 },
        "addr": { "type": "string", "minLength": 1, "maxLength": 256 }
      }
    },
    "p2p_libp2p_discovery": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "kademlia": { "type": "boolean" },
        "mdns": { "type": "boolean" },
        "rendezvous": { "type": "boolean" }
      }
    },
    "activity_source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["app_id", "source_kind"],
      "properties": {
        "app_id": { "type": "string", "minLength": 1, "maxLength": 64 },
        "source_kind": {
          "type": "string",
          "enum": [
            "steam_current_players",
            "epic_current_players",
            "gog_current_players",
            "ea_current_players",
            "community_json",
            "third_party_json",
            "none"
          ]
        },
        "endpoint_url": { "type": "string", "format": "uri" },
        "inline_json": { "type": "string" }
      }
    },
    "reward": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "reward_source": {
          "type": "string",
          "enum": ["static", "tokenomics"]
        },
        "emission_year": {
          "type": "integer",
          "minimum": 1,
          "maximum": 2200
        },
        "reward_block_secs": {
          "type": "integer",
          "minimum": 1,
          "maximum": 86400
        },
        "player_block_reward": {
          "type": "integer",
          "minimum": 0
        },
        "reward_adjustment_period_blocks": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100000000
        },
        "target_network_weight_units": {
          "type": "integer",
          "minimum": 0
        },
        "reward_adjustment_cap_bps": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10000
        },
        "collect_reward_bps": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10000
        },
        "store_reward_bps": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10000
        },
        "verify_reward_bps": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10000
        },
        "propose_reward_bps": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10000
        },
        "tail_emission_start_year": {
          "type": "integer",
          "minimum": 1,
          "maximum": 2200
        },
        "tail_emission_rate_bps": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10000
        },
        "game_mappings": {
          "type": "array",
          "items": { "$ref": "#/$defs/reward_game_mapping" }
        }
      }
    },
    "reward_game_mapping": {
      "type": "object",
      "additionalProperties": false,
      "required": ["process_name", "app_id"],
      "properties": {
        "process_name": { "type": "string", "minLength": 1, "maxLength": 256 },
        "app_id": { "type": "string", "minLength": 1, "maxLength": 64 },
        "game_coefficient_ppm": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1000000
        }
      }
    }
  }
}
